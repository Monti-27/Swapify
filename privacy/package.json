{
  "name": "@privacycash/api",
  "version": "0.0.1",
  "description": "Privacy Cash API Server",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node dist/src/index.js",
    "build": "npm run clean && npm run build:sdk && npm run build:ts && npm run copy:assets && npm run clean:source",
    "build:ts": "tsc --noEmitOnError false || echo 'TypeScript compilation completed with warnings'",
    "clean": "rm -rf dist",
    "clean:source": "find . -name '*.js' -path './src/*' -delete; find . -name '*.d.ts' -path './src/*' -delete; find . -name '*.js.map' -path './src/*' -delete; find . -name '*.d.ts.map' -path './src/*' -delete; find . -name '*.js' -path './privacy-cash-sdk/src/*' -delete; find . -name '*.d.ts' -path './privacy-cash-sdk/src/*' -delete; find . -name '*.js.map' -path './privacy-cash-sdk/src/*' -delete; find . -name '*.d.ts.map' -path './privacy-cash-sdk/src/*' -delete || true",
    "build:sdk": "node scripts/build-sdk.js",
    "copy:assets": "node scripts/copy-assets.js",
    "dev": "tsx src/index.ts",
    "dev:watch": "nodemon --exec tsx src/index.ts --watch src --ext ts,js"
  },
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@polymarket/clob-client": "^4.21.0",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@web-std/file": "^3.0.3",
    "bn.js": "^5.2.2",
    "bs58": "^6.0.0",
    "bullmq": "^5.58.5",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.0",
    "dotenv": "^16.3.1",
    "ethers": "^6.13.0",
    "expo-server-sdk": "^4.0.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "graphql": "^16.11.0",
    "graphql-request": "^7.2.0",
    "https-proxy-agent": "^7.0.6",
    "ioredis": "^5.7.0",
    "multer": "^1.4.0",
    "node-localstorage": "^3.0.5",
    "openai": "^4.104.0",
    "opossum": "^9.0.0",
    "privacycash": "file:./privacy-cash-sdk",
    "tsx": "^4.20.3",
    "undici": "^7.15.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10",
    "@types/opossum": "^8.1.9",
    "@typescript-eslint/eslint-plugin": "^6.12",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54",
    "jest": "^29.0.7",
    "nodemon": "^3.1.10",
    "ts-node-dev": "^2.0",
    "typescript": "^5.3.2"
  }
}

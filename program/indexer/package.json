{
  "name": "weswap-indexer",
  "version": "1.0.0",
  "description": "Event indexer for WeSwap protocol",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "dev": "ts-node --watch src/index.ts",
    "copy-artifacts": "node copy-artifacts.js",
    "update-idls": "cd .. && anchor build && cd indexer && npm run copy-artifacts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.0",
    "@solana/web3.js": "^1.98.0",
    "@supabase/supabase-js": "^2.39.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  }
}


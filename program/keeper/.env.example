# Solana RPC Configuration
RPC_URL=https://api.mainnet-beta.solana.com
# Alternative RPC URLs:
# RPC_URL=https://api.devnet.solana.com
# RPC_URL=https://your-custom-rpc-endpoint.com

# Keeper Private Key (base58 encoded) - KEEP THIS SECRET!
KEEPER_PRIVATE_KEY=your-base58-encoded-private-key-here

# Alternative: Keeper Keypair Path (if not using private key env var)
# KEEPER_KEYPAIR_PATH=./keeper-keypair.json

# WeSwap Program ID
PROGRAM_ID=AFhpyoVmDCEVofP3sqj8wCPSFYYGpL83sbXKuwMZtcoQ

# Jupiter Configuration
JUPITER_PROGRAM_ID=JUP6LkbZbjS1jKKwapdHNy74zcZ3tLUZoi5QNyVTaV4
JUPITER_API_URL=https://quote-api.jup.ag/v6
PRICE_API_URL=https://api.jup.ag

# Supabase Configuration (for strategy discovery)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Keeper Bot Settings
POLL_INTERVAL_MS=10000
MAX_STRATEGIES_PER_POLL=50
MIN_EXECUTION_AMOUNT=1000
SLIPPAGE_BPS=50

# Optional: Config file path (default: ./config.json)
# CONFIG_PATH=/path/to/config.json

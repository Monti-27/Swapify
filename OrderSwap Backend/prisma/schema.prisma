// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // User wallet information
  wallets   Wallet[]
  
  // Trading data
  strategies Strategy[]
  trades     Trade[]
  
  // Settings
  settings  Json?
  
  @@map("users")
}

model Wallet {
  id             String   @id @default(uuid())
  publicKey      String   @unique
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name           String?  // Optional wallet name
  isActive       Boolean  @default(true)
  type           String   @default("user") // 'user' | 'keeper' | 'admin'
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Relations
  strategies     Strategy[]
  trades         Trade[]
  
  @@map("wallets")
}

model Strategy {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  // --- NEW FIELDS FOR SMART CONTRACT ---
  pdaStrategy String?  @unique // On-chain address of the Strategy Account
  pdaEscrow   String?  // On-chain address of the Escrow Account
  programId   String?  // Which contract version (e.g. "AyFdzip...")
  strategyIndex Int?   // The 0-9 index used in the contract
  // -------------------------------------

  // Strategy details
  name        String
  description String?
  
  // Token information
  fromToken   String   // Token address to sell
  toToken     String   // Token address to buy
  
  // Order direction - NEW: Determines trigger comparison logic
  orderDirection String @default("buy") // 'buy' = trigger on price drop | 'sell' = trigger on price rise
  
  // Trigger conditions
  triggerType String   // 'price' | 'marketCap'
  triggerValue Float    // Target price or market cap
  
  // Amount to trade
  amountType  String   // 'percentage' | 'fixed'
  amount      Float
  
  // Stop loss & Take profit (optional)
  stopLoss    Float?
  takeProfit  Float?
  
  // Multi-step configuration (optional)
  nextStrategyId String?
  nextStrategy   Strategy? @relation("StrategyChain", fields: [nextStrategyId], references: [id])
  previousStrategy Strategy[] @relation("StrategyChain")
  
  // Status - UPDATED: Now includes 'filled' for TP/SL monitoring
  // 'created' | 'deposited' | 'active' | 'filled' | 'triggered' | 'completed' | 'cancelled' | 'failed'
  // NEW: 'filled' = Entry executed, monitoring for TP/SL exit
  status      String   @default("created")
  
  // Boomerang (Round Trip) Mode
  boomerangMode Boolean @default(false)  // If true, strategy flips on TP/SL instead of completing
  boomerangLeg  Int     @default(1)       // 1 = first leg, 2 = return leg
  originalFromToken String?              // Original sell token (for tracking after flip)
  originalToToken   String?              // Original buy token (for tracking after flip)
  
  // Entry execution details - NEW
  entryPrice      Float?     // Price at which entry was executed
  entryTokensReceived Float? // Tokens received on entry
  entryExecutedAt DateTime?  // When entry was executed
  
  // Exit execution details - NEW (for TP/SL)
  exitPrice       Float?     // Price at which exit was executed
  exitTokensReceived Float?  // Tokens received on exit
  exitExecutedAt  DateTime?  // When exit was executed
  exitType        String?    // 'takeProfit' | 'stopLoss'
  
  // Execution (legacy)
  depositedAt DateTime? // When user signed the deposit tx
  triggeredAt DateTime?
  completedAt DateTime?
  
  // Metadata
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  trades      Trade[]
  logs        StrategyLog[]
  
  @@index([userId])
  @@index([walletId])
  @@index([status])
  @@index([pdaStrategy]) // Critical for Indexer lookup
  @@map("strategies")
}

model Trade {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletId        String
  wallet          Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  strategyId      String?
  strategy        Strategy? @relation(fields: [strategyId], references: [id], onDelete: SetNull)
  
  // Trade details
  type            String   // 'buy' | 'sell' | 'swap'
  txType          String   @default("execution") // 'deposit' | 'withdraw' | 'execution'
  
  fromToken       String
  toToken         String
  fromAmount      Float
  toAmount        Float
  
  // Price information
  executionPrice  Float
  slippage        Float?
  
  // Transaction details
  txSignature     String?  @unique
  status          String   @default("pending") // 'pending' | 'completed' | 'failed'
  
  // Timestamps
  executedAt      DateTime @default(now())
  completedAt     DateTime?
  
  // Error handling
  error           String?
  
  // Metadata
  metadata        Json?
  
  @@index([userId])
  @@index([walletId])
  @@index([strategyId])
  @@index([status])
  @@index([executedAt])
  @@map("trades")
}

model StrategyLog {
  id          String   @id @default(uuid())
  strategyId  String
  strategy    Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  
  // Log details
  level       String   // 'info' | 'warning' | 'error'
  message     String
  data        Json?
  
  createdAt   DateTime @default(now())
  
  @@index([strategyId])
  @@index([createdAt])
  @@map("strategy_logs")
}

model PriceCache {
  id          String   @id @default(uuid())
  
  tokenAddress String  @unique
  price       Float
  marketCap   Float?
  volume24h   Float?
  
  source      String   // 'pyth' | 'dexscreener' | 'jupiter'
  
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  
  @@index([tokenAddress])
  @@index([updatedAt])
  @@map("price_cache")
}

model SystemLog {
  id          String   @id @default(uuid())
  
  level       String   // 'info' | 'warning' | 'error' | 'critical'
  service     String   // 'auth' | 'trade' | 'strategy' | 'monitoring' | 'system'
  message     String
  data        Json?
  
  createdAt   DateTime @default(now())
  
  @@index([service])
  @@index([level])
  @@index([createdAt])
  @@map("system_logs")
}

// Escrow model for tracking on-chain escrow account balances
model Escrow {
  id           String   @id @default(uuid())
  
  // Link to Strategy via pdaStrategy (the on-chain strategy PDA)
  pdaStrategy  String   @unique  // The strategy's on-chain PDA address
  pdaEscrow    String?  // The escrow account's on-chain PDA address
  
  // Owner information
  owner        String   // Wallet public key of the owner
  
  // Token information
  tokenMint    String   // The SPL token mint address
  
  // Balance tracking
  deposited    String   @default("0")  // Total deposited (stored as string for precision)
  withdrawn    String   @default("0")  // Total withdrawn (stored as string for precision)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@index([pdaStrategy])
  @@index([owner])
  @@map("escrows")
}

// ============================================================================
// ZK-Privacy Tables (Non-Custodial Cloud Backup)
// ============================================================================

// Stores encrypted commitment notes for user recovery
// SECURITY: Backend stores ONLY encrypted blobs - cannot read user's private data
model PrivacyCommitment {
  id              String   @id @default(uuid())
  
  // User identification
  walletAddress   String   // User's public key
  
  // Encrypted commitment data (user encrypts client-side)
  encryptedNote   String   // Base64 blob encrypted with user's key
  noteHash        String   @unique // Hash of the note for deduplication
  
  // Tracking
  amount          Float    // Amount in SOL (for display only)
  isRedeemed      Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  jobs            PrivacyJob[]
  transactions    PrivacyTransaction[]
  
  @@index([walletAddress])
  @@index([isRedeemed])
  @@map("privacy_commitments")
}

// Tracks BullMQ jobs for audit and recovery
model PrivacyJob {
  id              String   @id @default(uuid())
  
  // Link to commitment
  commitmentId    String?
  commitment      PrivacyCommitment? @relation(fields: [commitmentId], references: [id], onDelete: SetNull)
  
  // User tracking
  userPublicKey   String   // User's wallet for processor lookup
  
  // Job details
  bullmqJobId     String?  // BullMQ internal ID
  chunkAmount     Float
  chunkIndex      Int
  totalChunks     Int
  destinationAddress String
  
  // Timing
  delayMs         Int      // Scheduled delay in milliseconds
  scheduledAt     DateTime @default(now())
  processedAt     DateTime?
  
  // Status
  status          String   @default("pending") // 'pending' | 'processing' | 'completed' | 'failed'
  txSignature     String?  // Transaction signature if completed
  error           String?  // Error message if failed
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userPublicKey])
  @@index([commitmentId])
  @@index([status])
  @@index([scheduledAt])
  @@map("privacy_jobs")
}

// Audit trail for all privacy transactions
model PrivacyTransaction {
  id              String   @id @default(uuid())
  
  // Link to commitment
  commitmentId    String?
  commitment      PrivacyCommitment? @relation(fields: [commitmentId], references: [id], onDelete: SetNull)
  
  // User tracking
  walletAddress   String
  
  // Transaction details
  type            String   // 'shield' | 'unshield'
  amount          Float
  destinationAddress String?
  
  // Blockchain data
  txSignature     String?  @unique
  status          String   @default("pending") // 'pending' | 'confirmed' | 'failed'
  
  createdAt       DateTime @default(now())
  confirmedAt     DateTime?
  
  @@index([walletAddress])
  @@index([type])
  @@index([createdAt])
  @@map("privacy_transactions")
}
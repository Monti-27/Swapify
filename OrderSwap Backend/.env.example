# Application
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Database -VPS
#DATABASE_URL=


# Connect to Supabase via connection pooling
DATABASE_URL=

# Direct connection to the database. Used for migrations
DIRECT_URL=


# JWT
JWT_SECRET=your-secret-key-here-generate-new-one
JWT_EXPIRATION=7d

# Sol
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# For Production use premium RPC:
# SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# SOLANA_NETWORK=mainnet-beta

# Vault Program (for non-custodial trading)
VAULT_PROGRAM_ID=

# Jupiter Aggregator
JUPITER_API_URL=https://lite-api.jup.ag/swap/v1
JUPITER_TOKEN_API_URL=https://lite-api.jup.ag/tokens/v2
JUPITER_PRICE_API_URL=https://lite-api.jup.ag/price/v3

# Price Oracles
PYTH_PROGRAM_ID=
DEXSCREENER_API_URL=https://api.dexscreener.com/latest

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Monitoring Bot
MONITORING_INTERVAL=5000
PRICE_CHECK_BATCH_SIZE=50

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Blockchain Indexer
PROGRAM_ID=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-key


# KEEPER BOT (CRITICAL FOR AUTOMATED EXECUTION)
# The Keeper bot requires a funded Solana wallet to sign execution transactions.
KEEPER_PRIVATE_KEY=<base58-encoded-private-key>

# TRANSPARENCY ENGINE (Risk Scoring)
# Get your API key from https://helius.dev
HELIUS_API_KEY=your-helius-api-key
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
